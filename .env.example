# Release signing config
# Copy this file to .env and fill in your keystore details
# DO NOT commit .env to version control

# Path to your .jks keystore file (absolute or relative to android/app/)
KEYSTORE_PATH=upload-keystore.jks

# Keystore password (used for both store and key)
KEY_PASSWORD=your_keystore_password

# Key alias
KEY_ALIAS=your_key_alias
